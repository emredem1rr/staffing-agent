# Twilio WhatsApp
# Twilio Console → https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox için sabit numara; production'da kendi numaran
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhook (local test için ngrok, production için domain'in)
WEBHOOK_BASE_URL=http://localhost:8000

# Ollama (yerel LLM)
OLLAMA_URL=http://localhost:11434/api/generate
MODEL_NAME=llama3.1:8b

# Uygulama ayarları
APP_PORT=8000
DB_PATH=staffing_agent.db
# "whatsapp" → gerçek Twilio | "console" → sadece terminale yaz
MESSAGING_MODE=console

# Gmail (IMAP okuma + SMTP gönderme)
GMAIL_ADDRESS=your_email@gmail.com
# Google Hesabı → Güvenlik → 2 Adımlı Doğrulama → Uygulama Şifreleri → 16 haneli şifre
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_CHECK_ENABLED=true
EMAIL_CHECK_INTERVAL=60
